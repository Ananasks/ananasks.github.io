{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CV Content",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "intro", "entries"],
  "properties": {
    "title": {
      "type": "string"
    },
    "intro": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "title", "description"],
        "properties": {
          "date": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
