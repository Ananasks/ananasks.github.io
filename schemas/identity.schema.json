{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Identity Content",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "role",
    "resumeLabel",
    "languageLabel",
    "resumeHref",
    "photoAlt",
    "photoInitials",
    "nav"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "resumeLabel": {
      "type": "string"
    },
    "languageLabel": {
      "type": "string"
    },
    "resumeHref": {
      "type": "string"
    },
    "photoAlt": {
      "type": "string"
    },
    "photoSrc": {
      "type": ["string", "null"]
    },
    "photoInitials": {
      "type": "string"
    },
    "nav": {
      "type": "object",
      "additionalProperties": false,
      "required": ["about", "cv", "projects", "contacts"],
      "properties": {
        "about": {
          "type": "string"
        },
        "cv": {
          "type": "string"
        },
        "projects": {
          "type": "string"
        },
        "contacts": {
          "type": "string"
        }
      }
    }
  }
}
